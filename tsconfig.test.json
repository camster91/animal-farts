{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "tests/build",
    "rootDir": "src/pootbox",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "lib": ["ES2022", "DOM"],
    "types": ["react"]
  },
  "include": ["src/pootbox/audioManager.ts", "src/pootbox/recordings.ts", "src/pootbox/constants.ts", "src/pootbox/types.ts"]
}