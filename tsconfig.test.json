{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "tests/build",
    "rootDir": "src/pootbox",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": ["src/pootbox/audioManager.ts", "src/pootbox/recordings.ts"]
}
